# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Путь к FFmpeg (если не в PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Максимальный размер файла в байтах (по умолчанию 2 ГБ)
MAX_FILE_SIZE=2147483648

# Максимальная длительность видео в секундах (0 = без ограничений)
MAX_DURATION=0

# Папка для временных файлов
TEMP_DIR=./temp

# Папка с данными пользователей
DATA_DIR=./data

# Максимальное количество одновременных обработок
MAX_CONCURRENT_JOBS=10

# Rate limit: количество запросов в минуту на пользователя
RATE_LIMIT_PER_MINUTE=5

# Логирование: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Поддержка GPU (True/False)
USE_GPU=False
